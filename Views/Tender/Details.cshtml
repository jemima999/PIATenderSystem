@model PIATenderSystem.Models.Tender
@{
    ViewData["Title"] = "Tender Details";
}
<style>
    .details-wrap{padding:32px 40px;max-width:900px;margin:0 auto;}
    .details-heading{border-left:4px solid #C9A227;padding-left:14px;margin-bottom:6px;}
    .details-heading h1{font-family:'Poppins',sans-serif;font-weight:700;font-size:24px;color:#00543C;margin:0;}
    .details-subtitle{color:#6b7770;font-size:14px;margin:0 0 24px 18px;}
    .details-card{background:#fff;border-radius:10px;border:1px solid #eee;overflow:hidden;}
    .id-banner{background:#00543C;color:#fff;font-family:'Poppins',sans-serif;font-weight:600;font-size:15px;padding:16px 22px;}
    .row{display:flex;padding:16px 22px;border-bottom:1px solid #f0eee8;}
    .row:last-child{border-bottom:none;}
    .row .label{width:180px;flex-shrink:0;font-family:'Poppins',sans-serif;font-weight:700;font-size:14px;color:#1C2621;}
    .row .value{font-size:14px;color:#444;}
    .doc-btn{display:inline-flex;align-items:center;justify-content:center;width:40px;height:36px;border-radius:6px;background:#00543C;color:#fff;text-decoration:none;}
    .doc-btn:hover{background:#007A4D;}
    .doc-btn svg{width:16px;height:16px;}
    .back-link{display:inline-block;margin-top:20px;color:#00543C;font-family:'Poppins',sans-serif;font-weight:600;font-size:13px;text-decoration:none;}
    .back-link:hover{color:#C9A227;}
</style>

<div class="details-wrap">
    <div class="details-heading"><h1>Tender Details</h1></div>
    <p class="details-subtitle">@Model.Title</p>

    <div class="details-card">
        <div class="id-banner">Tender ID: @Model.TenderRefNo</div>

        <div class="row">
            <div class="label">Detail</div>
            <div class="value">@Model.Title</div>
        </div>
        <div class="row">
            <div class="label">Advertisement Date</div>
            <div class="value">@Model.StartDate.ToString("yyyy-MM-dd")</div>
        </div>
        <div class="row">
            <div class="label">Closing Date</div>
            <div class="value">@Model.ClosingDate.ToString("yyyy-MM-dd")</div>
        </div>
        <div class="row">
            <div class="label">Department</div>
            <div class="value">@Model.Department</div>
        </div>
        <div class="row">
            <div class="label">Documents</div>
            <div class="value">
                @if (!string.IsNullOrEmpty(Model.PdfFileName))
                {
                    <a class="doc-btn" asp-controller="Tender" asp-action="DownloadPdf" asp-route-id="@Model.Id" target="_blank" title="Download">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                    </a>
                }
                else
                {
                    <span style="color:#c8c3b6;font-size:13px;">Not available</span>
                }
            </div>
        </div>
    </div>

    <div style="margin-top:22px;">
        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Customer"))
        {
            @if (TempData["ApplySuccess"] != null)
            {
                <div style="background:#EAF3DE;color:#27500A;padding:12px 16px;border-radius:6px;margin-bottom:14px;font-size:13.5px;">
                    @TempData["ApplySuccess"]
                </div>
            }

            @if ((bool)ViewBag.AlreadyApplied)
            {
                <button type="button" disabled style="background:#ccc;color:#666;border:none;padding:12px 30px;border-radius:8px;font-family:'Poppins',sans-serif;font-weight:600;font-size:14px;cursor:not-allowed;">
                    Already Applied
                </button>

                {
                    var myDocs = (List<PIATenderSystem.Models.ApplicationDocument>)ViewBag.MyDocuments;

                    if (myDocs.Count > 0)
                    {
                        <div style="margin-top:14px;">
                            <div style="font-family:'Poppins',sans-serif;font-weight:600;font-size:13px;color:#1C2621;margin-bottom:6px;">Your uploaded documents:</div>
                            @foreach (var doc in myDocs)
                            {
                                <div style="margin-bottom:4px;">
                                    <a asp-controller="Tender" asp-action="DownloadApplicationDocument" asp-route-docId="@doc.Id" style="color:#00543C;font-size:13px;text-decoration:none;">
                                        📎 @doc.OriginalFileName
                                    </a>
                                </div>
                            }
                        </div>
                    }
                }
            }
            else
            {
                <form method="post" asp-controller="Tender" asp-action="Apply" asp-route-id="@Model.Id" enctype="multipart/form-data">
                    <div style="margin-bottom:14px;">
                        <label style="display:block;font-family:'Poppins',sans-serif;font-weight:600;font-size:13px;color:#1C2621;margin-bottom:6px;">
                            Upload Bid Documents (optional)
                        </label>
                        <input type="file" name="bidDocuments" multiple style="padding:8px 10px;border:1px solid #ddd;border-radius:6px;font-size:13px;background:#fff;" />
                    </div>
                    <button type="submit" style="background:#00543C;color:#fff;border:none;padding:12px 30px;border-radius:8px;font-family:'Poppins',sans-serif;font-weight:600;font-size:14px;cursor:pointer;">
                        Apply
                    </button>
                </form>
            }
        }
        else if (User.Identity == null || !User.Identity.IsAuthenticated)
        {
            <a asp-controller="Account" asp-action="Login" style="background:#00543C;color:#fff;border:none;padding:12px 30px;border-radius:8px;font-family:'Poppins',sans-serif;font-weight:600;font-size:14px;text-decoration:none;display:inline-block;">
                Login to Apply
            </a>
        }
    </div>

    <a class="back-link" asp-controller="Tender" asp-action="Index">&larr; Back to Tenders</a>
</div>
