@{
    ViewData["Title"] = "Login";
}
<style>
    :root{
        --pia-green-deep:#073B2C;
        --pia-green:#0B4D3A;
        --pia-green-mid:#0F6B4E;
        --gold:#C89B3C;
        --gold-light:#E8C77A;
        --gold-dark:#9C7524;
        --cream:#F7F4EC;
        --ink:#16231D;
        --muted:#657167;
        --line:#E4DFD0;
    }

    .hero{display:flex;min-height:calc(100vh - 88px);background:var(--cream);}

    /* ---------- LEFT: image carousel + brand copy ---------- */
    .hero-left{flex:1.1;position:relative;overflow:hidden;color:#fff;display:flex;flex-direction:column;justify-content:space-between;padding:56px 56px 0 56px;}
    .hero-slide{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transition:opacity 1.1s ease-in-out;}
    .hero-slide.active{opacity:1;}
    .hero-overlay{position:absolute;inset:0;background:linear-gradient(150deg, rgba(7,59,44,0.90) 0%, rgba(7,59,44,0.60) 55%, rgba(11,77,58,0.35) 100%);z-index:1;}
    .hero-content{position:relative;z-index:2;}

    .eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:11.5px;letter-spacing:2px;text-transform:uppercase;color:var(--gold-light);font-weight:600;margin-bottom:22px;}
    .eyebrow::before{content:"";width:26px;height:1px;background:var(--gold-light);}

    .hero-left h1{font-family:'Poppins',sans-serif;font-weight:700;font-size:42px;margin:0 0 14px;line-height:1.15;text-shadow:0 2px 10px rgba(0,0,0,0.25);}
    .hero-left p{font-size:16px;color:rgba(255,255,255,0.88);max-width:410px;line-height:1.7;text-shadow:0 1px 6px rgba(0,0,0,0.2);margin-bottom:30px;}

    .hero-dots{display:flex;gap:8px;position:relative;z-index:2;margin-bottom:36px;}
    .hero-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.5);border:none;padding:0;cursor:pointer;transition:background 0.2s, transform 0.2s;}
    .hero-dot.active{background:#fff;transform:scale(1.3);}

    /* airport status strip along the bottom */
    .board{position:relative;z-index:2;margin:0 -56px 0 -56px;padding:18px 56px;background:rgba(0,0,0,0.28);border-top:1px solid rgba(255,255,255,0.14);display:flex;gap:48px;flex-wrap:wrap;}
    .board .cell{display:flex;flex-direction:column;gap:4px;}
    .board .cell .k{font-size:10px;letter-spacing:1.6px;color:rgba(255,255,255,0.6);text-transform:uppercase;}
    .board .cell .v{font-family:'Poppins',sans-serif;font-size:14px;font-weight:600;color:var(--gold-light);}
    .board .cell .v.status{color:#7BD9A6;}

    /* ---------- RIGHT: boarding-pass sign-in card ---------- */
    .hero-right{flex:1;display:flex;align-items:center;justify-content:center;padding:40px;position:relative;}
    .hero-right::before{
        content:"";position:absolute;inset:0;
        background-image:radial-gradient(circle, rgba(11,77,58,0.06) 1px, transparent 1px);
        background-size:22px 22px;
        -webkit-mask-image:linear-gradient(180deg, transparent, black 15%, black 85%, transparent);
        mask-image:linear-gradient(180deg, transparent, black 15%, black 85%, transparent);
    }

    .pass{display:flex;background:#fff;border-radius:18px;box-shadow:0 24px 60px -18px rgba(7,59,44,0.35);overflow:visible;max-width:440px;width:100%;position:relative;z-index:2;}
    .pass-main{flex:1;padding:40px 38px 34px;position:relative;}
    .pass-stub{width:70px;background:var(--pia-green-deep);border-radius:0 18px 18px 0;display:flex;align-items:center;justify-content:center;}
    .pass-stub span{writing-mode:vertical-rl;transform:rotate(180deg);color:var(--gold-light);font-family:'Poppins',sans-serif;font-size:12px;letter-spacing:4px;font-weight:600;}
    .pass-main::after{content:"";position:absolute;right:0;top:14px;bottom:14px;border-left:2px dashed rgba(0,0,0,0.12);}
    .notch{position:absolute;right:-11px;width:22px;height:22px;background:var(--cream);border-radius:50%;z-index:3;}
    .notch.top{top:-11px;}
    .notch.bottom{bottom:-11px;}

    .tag{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--gold-dark);background:#FBF3E1;border:1px solid #F0DCA9;padding:5px 12px;border-radius:20px;margin-bottom:20px;}
    .pass-title{font-family:'Poppins',sans-serif;font-weight:700;font-size:28px;margin-bottom:6px;color:var(--pia-green-deep);}
    .pass-sub{font-size:14px;color:var(--muted);margin-bottom:28px;}

    .field{margin-bottom:18px;}
    .field label{display:block;font-size:13px;font-weight:600;color:var(--ink);margin-bottom:7px;letter-spacing:0.2px;}
    .input-wrap{position:relative;}
    .input-wrap svg{position:absolute;left:14px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--muted);opacity:.7;}
    .field input{width:100%;padding:13px 14px 13px 40px;border:1px solid #DDE3DC;border-radius:9px;font-size:14.5px;font-family:'Inter',sans-serif;color:var(--ink);background:#FBFBF8;transition:border-color .15s ease, box-shadow .15s ease;}
    .field input:focus{outline:none;border-color:var(--pia-green-mid);box-shadow:0 0 0 3px rgba(15,107,78,0.12);background:#fff;}

    .row-between{display:flex;align-items:center;justify-content:space-between;margin-bottom:26px;}
    .remember{display:flex;align-items:center;gap:7px;font-size:12.5px;color:var(--muted);}
    .remember input{width:14px;height:14px;accent-color:var(--pia-green-deep);}
    .forgot{font-size:12.5px;color:var(--pia-green-mid);text-decoration:none;font-weight:600;}

    .btn-pia{width:100%;padding:14px;background:linear-gradient(135deg,var(--pia-green-deep),var(--pia-green-mid));color:#fff;border:none;border-radius:9px;font-family:'Inter',sans-serif;font-weight:600;font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:opacity .15s ease, transform .05s ease;}
    .btn-pia:hover{opacity:.92;}
    .btn-pia:active{transform:translateY(1px);}

    .switch-link{text-align:center;font-size:13px;margin-top:22px;color:var(--muted);}
    .switch-link a{color:var(--gold-dark);font-weight:700;text-decoration:none;}

    .alert-pia{background:#fdecea;border:1px solid #f3c1bb;color:#a33;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:16px;}

    @@media (max-width:920px){
        .hero{flex-direction:column;}
        .hero-left{padding:40px 28px 0;min-height:340px;}
        .hero-left h1{font-size:30px;}
        .board{margin:0 -28px 0 -28px;padding:14px 28px;}
        .hero-right{padding:32px 20px;}
        .pass{max-width:100%;}
    }
</style>

<div class="hero">
    <div class="hero-left">
        <div class="hero-slide active" id="heroSlide1" style="background-image:url('@Url.Content("~/images/plane1.jpg")');"></div>
        <div class="hero-slide" id="heroSlide2" style="background-image:url('@Url.Content("~/images/plane2.jpg")');"></div>
        <div class="hero-slide" id="heroSlide3" style="background-image:url('@Url.Content("~/images/plane3.jpg")');"></div>
        <div class="hero-overlay"></div>

        <div class="hero-content">
            <div class="eyebrow">Procurement &amp; tender portal</div>
            <h1>Welcome back</h1>
            <p>Sign in to access your company's tender submissions, track status, and manage documents securely.</p>

            <div class="hero-dots">
                <button class="hero-dot active" data-i="0" aria-label="Slide 1"></button>
                <button class="hero-dot" data-i="1" aria-label="Slide 2"></button>
                <button class="hero-dot" data-i="2" aria-label="Slide 3"></button>
            </div>
        </div>

        <div class="board">
            <div class="cell"><span class="k">Portal</span><span class="v">Tender Submission</span></div>
            <div class="cell"><span class="k">Access</span><span class="v">Vendor Login</span></div>
            <div class="cell"><span class="k">Status</span><span class="v status">&#9679; Online</span></div>
            <div class="cell"><span class="k">Support</span><span class="v">24/7</span></div>
        </div>
    </div>

    <div class="hero-right">
        <div class="pass">
            <div class="pass-main">
                <div class="notch top"></div>
                <div class="notch bottom"></div>

                <div class="tag">Secure sign in</div>
                <div class="pass-title">Sign in</div>
                <div class="pass-sub">Access your company's tender account.</div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-pia">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <p style="margin:0;">@error.ErrorMessage</p>
                        }
                    </div>
                }

                <form asp-controller="Account" asp-action="Login" method="post">
                    <div class="field">
                        <label>Email</label>
                        <div class="input-wrap">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18v12H3z"/><path d="M3 7l9 6 9-6"/></svg>
                            <input type="email" name="email" required />
                        </div>
                    </div>
                    <div class="field">
                        <label>Password</label>
                        <div class="input-wrap">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="10" width="16" height="10" rx="2"/><path d="M8 10V7a4 4 0 018 0v3"/></svg>
                            <input type="password" name="password" required />
                        </div>
                    </div>

                    <div class="row-between">
                        <label class="remember"><input type="checkbox" name="remember" /> Remember me</label>
                        <a class="forgot" href="#">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn-pia">
                        Login to portal
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                    </button>
                </form>

                <div class="switch-link">
                    Don't have an account? <a asp-controller="Account" asp-action="Register">Register here</a>
                </div>
            </div>
            <div class="pass-stub"><span>BOARDING PASS</span></div>
        </div>
    </div>
</div>

<script>
    (function () {
        var slides = document.querySelectorAll('.hero-slide');
        var dots = document.querySelectorAll('.hero-dot');
        var current = 0;
        var total = slides.length;

        function goTo(i) {
            slides[current].classList.remove('active');
            dots[current].classList.remove('active');
            current = i;
            slides[current].classList.add('active');
            dots[current].classList.add('active');
        }

        dots.forEach(function (d) {
            d.addEventListener('click', function () {
                goTo(parseInt(d.dataset.i));
            });
        });

        setInterval(function () {
            goTo((current + 1) % total);
        }, 4000);
    })();
</script>
